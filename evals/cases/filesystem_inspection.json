  {
    "id": "planner-structured-grep",
    "user_input": "search src for TODOs",
    "planner_proposal": {
      "action_type": "shell_command",
      "mode": "structured",
      "command_family": "grep",
      "arguments": {
        "pattern": "TODO",
        "paths": [
          "src"
        ],
        "ignore_case": false,
        "line_number": true,
        "fixed_strings": false,
        "recursive": true,
        "files_with_matches": false,
        "max_count": 5
      },
      "command": null,
      "summary": "find TODO",
      "explanation": "use grep",
      "risk_level": "safe",
      "needs_confirmation": true,
      "notes": []
    },
    "expected_mode": "structured",
    "expected_command_family": "grep",
    "expected_risk_level": "safe",
    "expected_acceptance": true,
    "expected_rendered_command": "grep -n -r -m 5 TODO src",
    "expected_argv": [
      "grep",
      "-n",
      "-r",
      "-m",
      "5",
      "TODO",
      "src"
    ]
  },
